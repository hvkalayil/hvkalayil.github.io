---
import MyWorks from "./my_works/MyWorks.astro";
import AboutMe from "./about_me/AboutMe.astro";
---

<script>
    const onMounted = () => {
        let currentPage = "worksPage";

        const myWorksBtn = document.getElementById("workBtn");
        const aboutMeBtn = document.getElementById("aboutBtn");

        if (!myWorksBtn || !aboutMeBtn) return;

        const changePage = (pageName = "worksPage") => {
            if (currentPage === pageName) return;
            const curr = document.getElementById(currentPage);
            const nxt = document.getElementById(pageName);

            if (!curr || !nxt) return;

            // Animate out current page smoothly
            curr.style.transition = "opacity 0.25s ease-out, transform 0.25s ease-out";
            curr.style.opacity = "0";
            curr.style.transform = "translateY(15px) scale(0.98)";

            setTimeout(() => {
                curr.style.display = "none";
                curr.style.transform = ""; // Reset for future usage
                
                // Prepare next page invisibly
                nxt.style.display = "flex";
                nxt.style.opacity = "0";
                nxt.style.transform = "translateY(25px) scale(0.98)";
                nxt.style.transition = "none";
                
                // Trigger reflow to apply none transition
                void nxt.offsetHeight;

                // Animate in next page luxuriously
                nxt.style.transition = "opacity 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1)";
                nxt.style.opacity = "1";
                nxt.style.transform = "translateY(0) scale(1)";
                
                currentPage = pageName;
            }, 250);
        };

        myWorksBtn.addEventListener("click", () => changePage("worksPage"));
        aboutMeBtn.addEventListener("click", () => changePage("aboutPage"));

        document.removeEventListener("DOMContentLoaded", onMounted);
    };

    document.addEventListener("DOMContentLoaded", onMounted);
</script>

<div
    class="flex w-full bg-primary-900 dark:bg-primary-dark-900 min-h-screen md:w-3/4 overflow-visible overflow-x-hidden relative isolate bg-elegant-pulse"
>
    <MyWorks />

    <div class="body-container content-start" id="aboutPage">
        <AboutMe />
    </div>
</div>
