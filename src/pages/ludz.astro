---
import BaseHead from "../components/shared/BaseHead.astro";
import NavBar from "../components/portfolio/NavBar.astro";
import LudzEditor from "../components/ludz/LudzEditor.svelte";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title="Ludz Flash Cards" description="Flash card builder for nursing students" />
  </head>

  <body
    class="bg-primary-900 text-body dark:bg-primary-dark-900 dark:text-body-dark"
  >
    <main class="font-body">
      <section class="flex-1 min-h-screen overflow-y-auto bg-primary-900/80 dark:bg-primary-dark-900/80">
          <div class="mx-auto max-w-6xl py-6 md:py-10 px-4 md:px-8">
            <header class="mb-6">
              <h1 class="text-2xl font-bold text-gray-100">
                Ludz – Nursing Flash Card Builder
              </h1>
              <p class="mt-1 text-sm text-gray-400">
                Create simple, Tamil-friendly flash card layouts with text and images, preview them in real time, and export as PDF.
              </p>
            </header>

            <LudzEditor client:load />
          </div>
        </section>
    </main>
  </body>
</html>


